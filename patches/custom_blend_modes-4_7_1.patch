+		case RSE::BLEND_MODE_ALPHA_TO_COVERAGE:
+			return "alpha_to_coverage";
+		case RSE::BLEND_MODE_DISABLED:
+			return "disabled";
+		default:
+			break;
+	}
+	return "mix";
+}
+
+inline StringName blend_mode_name(RSE::BlendMode p_mode) {
+	return "blend_" + blend_mode_to_string(p_mode);
+}
