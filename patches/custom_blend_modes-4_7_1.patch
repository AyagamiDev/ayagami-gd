+
+inline String blend_mode_to_string(RSE::BlendMode p_mode) {
+	switch (p_mode) {
+		case RSE::BLEND_MODE_MIX:
+			return "mix";
+		case RSE::BLEND_MODE_ADD:
+			return "add";
+		case RSE::BLEND_MODE_SUB:
+			return "sub";
+		case RSE::BLEND_MODE_MUL:
